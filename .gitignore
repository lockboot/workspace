# --- Sub-repositories -------------------------------------------------------
# These are independent git repos, managed via the Makefile (make clone / pull).
# The workspace repo does NOT track them (no submodules).
/os402/
/stage0/
/stage1/
/vaportpm/
/vaportpm-zk/
/wavebend.org/

# --- Shared Cargo home (CARGO_HOME=$WORKSPACE/.cargo) ------------------------
# We KEEP .cargo/config.toml (the shared build config, tracked below) but ignore
# everything cargo generates: the registry cache, git checkouts, installed
# binaries and lock files. This is what makes the compile/registry cache shared
# across every sub-repo without a Docker volume.
/.cargo/*
!/.cargo/config.toml

# --- Shared rustup home (RUSTUP_HOME=$WORKSPACE/.rustup) ---------------------
# Fully generated: toolchains, downloads, settings. Shared across sub-repos.
/.rustup/

# --- Build output -----------------------------------------------------------
# Per-repo target/ dirs live inside the (ignored) sub-repo dirs, but ignore any
# stray ones at the workspace root too.
/target/

# --- Devcontainer ------------------------------------------------------------
# Per-host uid/gid + device gids, regenerated by prepare-env.sh on every start.
/.devcontainer/docker-compose.host.yml

# --- Editors / OS -----------------------------------------------------------
*.swp
.DS_Store

.gitconfig
.vscode-server
.ssh
.gnupg
.dotnet
.cache
.claude
.claude.json
.lesshst
.local
.config
.docker
